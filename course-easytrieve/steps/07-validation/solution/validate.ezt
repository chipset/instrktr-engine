* -----------------------------------------------
* EMPVAL   - Employee file validation program
* -----------------------------------------------

  FILE EMPLOYEE EMPDD
  EMP-ID       1   9  A
  EMP-NAME    10  30  A
  EMP-DEPT    40   4  A
  EMP-SALARY  44   7  N  2
  EMP-STATUS  51   1  A

  W
  ERROR-COUNT  N   6     VALUE 0
  ERR-FIELD    A  12     VALUE SPACES
  ERR-MSG      A  40     VALUE SPACES
  RESULT-MSG   A  20     VALUE SPACES

  P
  REPORT ERRLIST  PRINTER
    TITLE   'Employee File Validation Errors'
    HEADING 'ID'      'Field'     'Error Message'
    LINE    EMP-ID    ERR-FIELD   ERR-MSG

  REPORT SUMMARY  PRINTER
    TITLE   'Validation Summary'
    FOOTING 'Error Count'  ERROR-COUNT  RESULT-MSG

  * Check: Employee ID not blank
  IF EMP-ID EQ SPACES
    MOVE 'EMP-ID'          TO ERR-FIELD
    MOVE 'ID is blank'     TO ERR-MSG
    PRINT ERRLIST
    COMPUTE ERROR-COUNT = ERROR-COUNT + 1
  END-IF

  * Check: Employee name not blank
  IF EMP-NAME EQ SPACES
    MOVE 'EMP-NAME'        TO ERR-FIELD
    MOVE 'Name is blank'   TO ERR-MSG
    PRINT ERRLIST
    COMPUTE ERROR-COUNT = ERROR-COUNT + 1
  END-IF

  * Check: Department not blank
  IF EMP-DEPT EQ SPACES
    MOVE 'EMP-DEPT'        TO ERR-FIELD
    MOVE 'Dept is blank'   TO ERR-MSG
    PRINT ERRLIST
    COMPUTE ERROR-COUNT = ERROR-COUNT + 1
  END-IF

  * Check: Salary is numeric
  IF NOT EMP-SALARY NUMERIC
    MOVE 'EMP-SALARY'          TO ERR-FIELD
    MOVE 'Salary not numeric'  TO ERR-MSG
    PRINT ERRLIST
    COMPUTE ERROR-COUNT = ERROR-COUNT + 1
  ELSE
    * Check: Salary greater than zero (only if numeric)
    IF EMP-SALARY LE 0
      MOVE 'EMP-SALARY'        TO ERR-FIELD
      MOVE 'Salary is zero'    TO ERR-MSG
      PRINT ERRLIST
      COMPUTE ERROR-COUNT = ERROR-COUNT + 1
    END-IF
  END-IF

  * Check: Status is a valid code
  IF EMP-STATUS NE 'A' AND EMP-STATUS NE 'T'
    MOVE 'EMP-STATUS'          TO ERR-FIELD
    MOVE 'Invalid status code' TO ERR-MSG
    PRINT ERRLIST
    COMPUTE ERROR-COUNT = ERROR-COUNT + 1
  END-IF

  LABEL EOF
  IF ERROR-COUNT GT 0
    MOVE 'VALIDATION FAILED' TO RESULT-MSG
  ELSE
    MOVE 'VALIDATION PASSED' TO RESULT-MSG
  END-IF
  PRINT SUMMARY
