{
  "name": "instrktr",
  "displayName": "Instrktr",
  "description": "Interactive course engine — run hands-on coding courses directly inside VS Code",
  "version": "0.3.10",
  "publisher": "instrktr",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1e2a3a",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/instrktr/instrktr-engine"
  },
  "keywords": [
    "learning",
    "courses",
    "education",
    "interactive",
    "training"
  ],
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:instrktr.catalog",
    "onView:instrktr.panel",
    "onCommand:instrktr.openLocalCourse",
    "onCommand:instrktr.browseCourses",
    "onCommand:instrktr.refreshRegistry",
    "onCommand:instrktr.checkWork",
    "onCommand:instrktr.nextStep",
    "onCommand:instrktr.previousStep",
    "onCommand:instrktr.jumpToStep",
    "onCommand:instrktr.restartCourse",
    "onCommand:instrktr.signIn",
    "onCommand:instrktr.signOut"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "instrktr.checkWork",
        "title": "Instrktr: Check My Work"
      },
      {
        "command": "instrktr.nextStep",
        "title": "Instrktr: Next Step"
      },
      {
        "command": "instrktr.previousStep",
        "title": "Instrktr: Previous Step"
      },
      {
        "command": "instrktr.jumpToStep",
        "title": "Instrktr: Jump to Step…"
      },
      {
        "command": "instrktr.openLocalCourse",
        "title": "Instrktr: Open Local Course Folder"
      },
      {
        "command": "instrktr.startCourse",
        "title": "Instrktr: Start Course"
      },
      {
        "command": "instrktr.browseCourses",
        "title": "Instrktr: Browse Courses"
      },
      {
        "command": "instrktr.refreshRegistry",
        "title": "Instrktr: Refresh Course Catalog"
      },
      {
        "command": "instrktr.restartCourse",
        "title": "Instrktr: Restart Course"
      },
      {
        "command": "instrktr.signIn",
        "title": "Instrktr: Sign in with GitHub"
      },
      {
        "command": "instrktr.signOut",
        "title": "Instrktr: Sign out of GitHub"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "instrktr",
          "title": "Instrktr",
          "icon": "media/icon-activity.svg"
        }
      ]
    },
    "views": {
      "instrktr": [
        {
          "type": "webview",
          "id": "instrktr.catalog",
          "name": "Browse Courses",
          "when": "!instrktr.courseLoaded || instrktr.catalogVisible"
        },
        {
          "type": "webview",
          "id": "instrktr.panel",
          "name": "Active Course"
        }
      ]
    },
    "keybindings": [
      {
        "command": "instrktr.checkWork",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "instrktr.courseLoaded"
      },
      {
        "command": "instrktr.nextStep",
        "key": "ctrl+shift+]",
        "mac": "cmd+shift+]",
        "when": "instrktr.courseLoaded"
      },
      {
        "command": "instrktr.previousStep",
        "key": "ctrl+shift+[",
        "mac": "cmd+shift+[",
        "when": "instrktr.courseLoaded"
      }
    ],
    "configuration": {
      "title": "Instrktr",
      "properties": {
        "instrktr.registryUrl": {
          "type": "string",
          "default": "",
          "description": "URL to the course registry.json"
        },
        "instrktr.startupCourse": {
          "type": "string",
          "default": "",
          "description": "Course ID from the registry to automatically install and start when VS Code opens (e.g. \"git-basics\")."
        },
        "instrktr.localCoursePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a local course folder to automatically start when VS Code opens. Takes precedence over instrktr.startupCourse."
        },
        "instrktr.debugValidatorCommands": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "markdownDescription": "Log validator command execution and permission decisions to the **Instrktr** output channel for debugging."
        },
        "instrktr.disableValidatorCommandSecurityChecks": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "markdownDescription": "Disable validator command permission prompts and run validator commands without asking. **Only enable this for courses you fully trust.**"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "compile-tests": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^10.2.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "marked": "^18.0.2",
    "yauzl": "^3.3.0"
  }
}
